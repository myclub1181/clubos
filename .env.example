# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:pass@localhost:5432/clubos

# ── Auth ─────────────────────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3001
NEXTAUTH_SECRET=change-me

# ── Stripe (platform account — receives ClubOS subscription payments) ────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs for the ClubOS-own subscription tiers. Create one recurring
# Price per tier in your Stripe dashboard ($50/mo, $99/mo, $199/mo) and paste
# the price IDs here. Test mode and live mode use different IDs.
STRIPE_PRICE_GROWTH=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_ENTERPRISE=price_...

# ── Plaid (optional, for bank reconciliation) ────────────────────────────────
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox

# ── Email (optional, falls back to console.log if unset) ─────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
EMAIL_FROM="AthletixOS <no-reply@clubos.app>"

# ── File storage ─────────────────────────────────────────────────────────────
# Where uploaded images/docs are written. Defaults to ./storage/uploads if unset.
# Files are NEVER served as static — they go through /api/files/[id] which
# enforces club scoping.
UPLOADS_DIR=
